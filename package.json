{
  "name": "vipro-multi-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "Responsive multi-tracker web app with Supabase cloud sync.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prepare": "husky",
    "commitlint": "commitlint --from HEAD~1 --to HEAD --verbose",
    "release:first": "commit-and-tag-version --first-release",
    "release:first:dry": "commit-and-tag-version --first-release --dry-run",
    "release": "commit-and-tag-version",
    "release:dry": "commit-and-tag-version --dry-run"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lemonroti/vipro-multi-tracker.git"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "commit-and-tag-version": "13.0.0",
    "eslint": "10.7.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "supabase": "2.109.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.110.7",
    "zod": "4.4.3"
  }
}
